# General
# 忽略操作系统、IDE、构建产物和常见语言的临时/二进制文件

res/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
dist/
build/
.cache/
.next/
.nuxt/
.out/
parcel-cache/
.vite/

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
ENV/
env/
build/
dist/
*.egg-info/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.pyre/
.ipynb_checkpoints/
env/*

# Java / JVM
target/
*.class
*.jar
*.war
*.ear
*.iml
.gradle/

# Logs, temp
*.log
logs/
tmp/
temp/
*.tmp

# Coverage
.coverage
coverage/
htmlcov/

# Databases
*.sqlite3
*.db

# Secrets / keys / certificates
.env
.env.local
.env.*.local
*.pem
*.key
*.pfx
*.crt

# Docker
.dockerignore
docker-compose.override.yml

# Misc
*.swp
*.swo
*.bak
*.orig

# Terraform
.terraform/

# macOS Finder metadata
.fseventsd

